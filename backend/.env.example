# ===========================================
# OSEAN Backend - Variables d'environnement
# ===========================================

# Database (PostgreSQL)
# En local avec Docker: postgresql://osean:osean_secret@localhost:5433/osean_db?schema=public
# Sur Railway: Utiliser la variable DATABASE_URL fournie automatiquement
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# JWT Configuration
# IMPORTANT: Générer des clés sécurisées en production!
# Utiliser: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Application
PORT=3000
NODE_ENV=production

# Frontend URL (pour CORS)
# En local: http://localhost:3001
# En production: https://votre-app.vercel.app
FRONTEND_URL="https://your-frontend-domain.vercel.app"

# ===========================================
# Variables Railway (automatiques)
# ===========================================
# RAILWAY_ENVIRONMENT - Environnement Railway
# RAILWAY_PROJECT_ID - ID du projet
# RAILWAY_SERVICE_ID - ID du service
# DATABASE_URL - URL PostgreSQL (si vous ajoutez une DB Railway)
